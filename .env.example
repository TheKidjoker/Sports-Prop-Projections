# Supabase Auth & Persistence (required for sign-in and persistent bet tracking)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_KEY=your-service-role-key

# Admin access (comma-separated emails)
ADMIN_EMAILS=your-email@example.com

# Optional APIs
ODDS_API_IO_KEY=
ODDS_API_KEY=
OPENWEATHER_API_KEY=
BALLDONTLIE_API_KEY=

# Soccer (API-Football) — 100 calls/day free tier
FOOTBALL_API_KEY=

# Discord Webhook — sends STRONG PLAY alerts and daily summaries
DISCORD_WEBHOOK_URL=

# Scheduler — enables automated scans, grading, and closing line fetches
ENABLE_SCHEDULER=false
